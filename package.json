{
  "name": "pang-web",
  "private": true,
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "lint": "turbo run lint",
    "format": "prettier --write \"**/*.{ts,tsx,md}\"",
    "check-types": "turbo run check-types",
    "clean": "turbo run clean",
    "ci:build": "pnpm build",
    "ci:test": "echo \"No tests specified\" && exit 0",
    "ci:lint": "pnpm lint && pnpm check-types"
  },
  "devDependencies": {
    "prettier": "^3.5.3",
    "turbo": "^2.4.4",
    "typescript": "5.8.2"
  },
  "packageManager": "pnpm@9.0.0",
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "@types/react": "^18.2.0",
    "@types/react-dom": "^18.2.0",
    "axios": "^1.9.0",
    "babel-plugin-styled-components": "^2.1.4",
    "rc-slider": "^11.1.8",
    "react-icons": "^5.5.0",
    "styled-components": "^6.1.15"
  }
}
